void handleCommand() {
  if (server.hasArg("id")) {
    int id = server.arg("id").toInt();
    switch(id) {
      case 1: p_maxBrightness = max(2, p_maxBrightness - 2); break; // Parlaklığı iyice kıs
      case 2: p_maxBrightness = min(50, p_maxBrightness + 2); break; 
      case 3: p_sinusAntiAlias = !p_sinusAntiAlias; break;          // Sinüs filtresi toggle
      case 4: 
        p_scrollSpeed -= 40;
        if(p_scrollSpeed < 60) p_scrollSpeed = 220; // Döngüsel hız ayarı
        break; 
      case 5:
        p_colorMode++;
        if(p_colorMode > 3) p_colorMode = 1;
        break;
    }
  }
  server.sendHeader("Location", "/");
  server.send(302, "text/plain", "");
}

void setup() {
  Serial.begin(115200);
  for (int i = 0; i < NUM_STRIPS; i++) strips[i].begin();
  initializeDefaultMap(); 
  refreshMatrix();

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { delay(500); Serial.print("."); }
  
  configTime(3 * 3600, 0, "pool.ntp.org");

  server.on("/", handleRoot);
  server.on("/cmd", handleCommand);
  server.begin();
}

void loop() {
  server.handleClient();
  if(clockMode) updateClockScroll();
  delay(5);
}
